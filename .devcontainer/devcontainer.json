{
    "name": "Go Dev Environment",
    // 使用微软官方维护的 Go 容器镜像（包含 Go 环境和基础工具）
    "image": "mcr.microsoft.com/devcontainers/go:1.26-bookworm",

    // 容器启动后自动安装的 VS Code 插件
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.Go",          // Go 核心插件
                "editorconfig.editorconfig", // 代码格式规范
                "eamodio.gitlens"     // 强大的 Git 增强
            ],
            "settings": {
                "go.toolsManagement.checkForUpdates": "local",
                "go.useLanguageServer": true
            }
        }
    },

    // 自动安装一些常用的附加功能（比如常见的 Linux 工具）
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "configureZshAsDefaultShell": true
        }
    },

    // 以前台用户身份运行，避免权限问题
    "remoteUser": "vscode"
}