{
    "name": "Go Dev with Oh My Zsh",
    "image": "mcr.microsoft.com/devcontainers/go:1.26-bookworm",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
        "installZsh": true,
        "configureZshAsDefaultShell": true,
        "installOhMyZsh": true
    }
    },
    "customizations": {
        "vscode": {
            "settings": {
                // 确保 VS Code 集成终端默认打开 Zsh
                "terminal.integrated.defaultProfile.linux": "zsh",
                "go.useLanguageServer": true,
                // 关键：防止在代理不稳定时频繁弹出更新提示
                "go.toolsManagement.checkForUpdates": "local",
                // 关键：保存时自动格式化代码并整理 import（Go 开发标配）
                "editor.formatOnSave": true,
                "editor.codeActionsOnSave": {
                    "source.organizeImports": "explicit"
                },
                // 让 VS Code 窗口标题显示当前的 WSL 路径
                "window.title": "${dirty}${activeEditorShort}${separator}${rootName} [WSL]"
            },
            "extensions": [
                "golang.Go",
                "eamodio.gitlens"
            ]
        }
    },
    // 微软镜像默认创建的用户是 vscode
    "remoteUser": "vscode"
}